# Copy this file to .env and fill in the values you need.

# Required for dub_poc.py (ElevenLabs cloud pipeline).
# Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Required for experiments/indicf5_dub_poc.py and experiments/indic_parler_tts_dub_poc.py
# (both use gated Hugging Face models). Not needed for the recommended
# timed_chatterbox_dub_poc.py or kokoro_dub_poc.py pipelines.
# Get one at https://huggingface.co/settings/tokens, and accept access on the
# specific gated model page first (e.g. https://huggingface.co/ai4bharat/IndicF5).
HF_TOKEN=
